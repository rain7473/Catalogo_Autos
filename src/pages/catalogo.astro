---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VehicleCard from '../components/VehicleCard.astro';
import VehicleDetailModal from '../components/VehicleDetailModal.astro';
import { vehiculos } from '../vehiculos';

const disponibles = vehiculos.filter((vehiculo) => vehiculo.estado === 'disponible');
const precioMinimo = Math.min(...vehiculos.map((vehiculo) => vehiculo.precio));
const precioMaximo = Math.max(...vehiculos.map((vehiculo) => vehiculo.precio));
const marcas = [...new Set(vehiculos.map((vehiculo) => vehiculo.marca))].sort();
const transmisiones = [...new Set(vehiculos.map((vehiculo) => vehiculo.transmision))].sort();
const combustibles = [...new Set(vehiculos.map((vehiculo) => vehiculo.combustible))].sort();
const anios = [...new Set(vehiculos.map((vehiculo) => vehiculo.anio))].sort((a, b) => b - a);
---

<Layout
  title="Catálogo - Autos La Fe"
  description="Explora el catálogo completo de vehículos de Autos La Fe en San Pedro Sula. Filtra por marca, año, precio y características."
>
  <Header />

  <!-- Encabezado de página -->
  <section class="relative overflow-hidden bg-zinc-950 text-white">
    <div class="bg-grid-dark absolute inset-0" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -top-40 right-[-8%] h-[380px] w-[380px] rounded-full bg-red-700/25 blur-[120px]" aria-hidden="true"></div>

    <div class="relative mx-auto flex max-w-screen-2xl flex-wrap items-end justify-between gap-6 px-4 pb-10 pt-10 sm:px-6 lg:px-8 lg:pb-12 lg:pt-14">
      <div>
        <nav class="text-xs font-semibold text-zinc-400" aria-label="Ruta de navegación">
          <a href="/" class="cursor-pointer transition-colors duration-200 hover:text-white">Inicio</a>
          <span class="mx-1.5 text-zinc-600">/</span>
          <span class="text-zinc-200">Catálogo</span>
        </nav>
        <h1 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Catálogo de vehículos</h1>
        <p class="mt-2 max-w-xl text-sm leading-6 text-zinc-300 sm:text-base">
          Todas nuestras unidades verificadas. Usa los filtros para encontrar exactamente lo que buscas.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-2.5 text-sm font-semibold">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3.5 py-2">
          <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
          {disponibles.length} disponibles
        </span>
        <span class="rounded-full border border-white/15 bg-white/5 px-3.5 py-2">
          Desde ${precioMinimo.toLocaleString('en-US')}
        </span>
      </div>
    </div>
  </section>

  <main class="mx-auto max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8 lg:py-10">
    <!-- Toggle de filtros en móvil -->
    <div class="mb-4 lg:hidden">
      <button
        id="filters-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="filters-panel"
        class="inline-flex h-11 w-full cursor-pointer items-center justify-center gap-2 rounded-xl border border-zinc-300 bg-white px-4 text-sm font-bold text-zinc-800 shadow-sm transition-colors duration-200 hover:border-red-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6h18" />
          <path d="M7 12h10" />
          <path d="M10 18h4" />
        </svg>
        <span id="filters-toggle-label">Mostrar filtros</span>
      </button>
    </div>

    <div class="lg:grid lg:grid-cols-[290px_minmax(0,1fr)] lg:items-start lg:gap-8">
      <!-- Filtros -->
      <aside
        id="filters-panel"
        class="hidden lg:sticky lg:top-24 lg:block"
        aria-label="Filtros del catálogo"
      >
        <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between gap-3">
            <h2 class="text-sm font-extrabold uppercase tracking-[0.16em] text-zinc-950">Filtros</h2>
            <button
              id="clear-filters"
              type="button"
              class="cursor-pointer text-xs font-bold text-red-700 transition-colors duration-200 hover:text-red-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
            >
              Limpiar todo
            </button>
          </div>

          <label class="relative mt-4 block">
            <span class="sr-only">Buscar vehículo</span>
            <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4.5 w-4.5 -translate-y-1/2 text-zinc-400" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
            <input
              id="search-input"
              type="search"
              placeholder="Buscar marca o modelo"
              class="h-11 w-full rounded-xl border border-zinc-200 bg-zinc-50 pl-10 pr-3 text-sm text-zinc-950 placeholder-zinc-400 outline-none transition focus:border-red-700 focus:bg-white focus:ring-4 focus:ring-red-100"
            />
          </label>

          <div class="mt-4">
            <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-zinc-500">Estado</span>
            <div class="grid gap-1 rounded-xl bg-zinc-100 p-1" role="tablist" aria-label="Estado del vehículo">
              {[
                { id: 'todos', label: 'Todos' },
                { id: 'disponible', label: 'Disponibles' },
                { id: 'vendido', label: 'Vendidos' },
              ].map((tab) => (
                <button
                  data-tab={tab.id}
                  class="tab-btn flex h-9 min-w-0 cursor-pointer items-center gap-2 rounded-lg px-3 text-left text-sm font-bold text-zinc-600 transition hover:text-zinc-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 data-[active=true]:bg-red-700 data-[active=true]:text-white data-[active=true]:shadow-sm"
                  type="button"
                  role="tab"
                  aria-selected={tab.id === 'disponible' ? 'true' : 'false'}
                  data-active={tab.id === 'disponible' ? 'true' : 'false'}
                >
                  <span class="h-1.5 w-1.5 flex-none rounded-full bg-current opacity-60"></span>
                  {tab.label}
                </button>
              ))}
            </div>
          </div>

          <div class="mt-4 space-y-4">
            <label class="block">
              <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-zinc-500">Marca</span>
              <select id="brand-filter" class="filter-field">
                <option value="">Todas</option>
                {marcas.map((marca) => <option value={marca}>{marca}</option>)}
              </select>
            </label>

            <label class="block">
              <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-zinc-500">Año</span>
              <select id="year-filter" class="filter-field">
                <option value="">Todos</option>
                {anios.map((anio) => <option value={anio}>{anio}</option>)}
              </select>
            </label>

            <label class="block">
              <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-zinc-500">Transmisión</span>
              <select id="transmission-filter" class="filter-field">
                <option value="">Todas</option>
                {transmisiones.map((transmision) => <option value={transmision}>{transmision}</option>)}
              </select>
            </label>

            <label class="block">
              <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-zinc-500">Combustible</span>
              <select id="fuel-filter" class="filter-field">
                <option value="">Todos</option>
                {combustibles.map((combustible) => <option value={combustible}>{combustible}</option>)}
              </select>
            </label>

            <label class="block">
              <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-zinc-500">Precio máximo</span>
              <select id="price-filter" class="filter-field">
                <option value="">Sin límite</option>
                <option value="22000">Hasta $22,000</option>
                <option value="25000">Hasta $25,000</option>
                <option value="30000">Hasta $30,000</option>
                <option value={precioMaximo}>Hasta ${precioMaximo.toLocaleString('en-US')}</option>
              </select>
            </label>
          </div>
        </div>
      </aside>

      <!-- Resultados -->
      <div class="mt-6 lg:mt-0">
        <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
          <p id="vehicle-counter" class="text-sm font-bold text-zinc-700" aria-live="polite">
            {disponibles.length} vehículos disponibles desde ${precioMinimo.toLocaleString('en-US')}
          </p>
          <p class="text-xs font-semibold text-zinc-400">
            Actualizado al día · Consulta directa por WhatsApp
          </p>
        </div>

        <section id="vehicles-grid" class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4" aria-live="polite">
          {vehiculos.map((vehiculo) => (
            <VehicleCard vehiculo={vehiculo} />
          ))}
        </section>

        <section id="no-results" class="hidden rounded-2xl border border-dashed border-zinc-300 bg-white py-16 text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-zinc-100">
            <svg class="h-8 w-8 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
              <path d="M8 11h6" />
            </svg>
          </div>
          <h2 class="text-xl font-extrabold tracking-tight text-zinc-900">No hay vehículos con esos filtros</h2>
          <p class="mx-auto mt-2 max-w-sm text-sm leading-6 text-zinc-500">
            Prueba quitando algún filtro o busca por otra marca o modelo.
          </p>
          <button
            id="no-results-clear"
            type="button"
            class="mt-5 inline-flex h-11 cursor-pointer items-center justify-center rounded-xl bg-red-700 px-5 text-sm font-bold text-white shadow-sm transition-colors duration-200 hover:bg-red-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
          >
            Limpiar filtros
          </button>
        </section>
      </div>
    </div>
  </main>

  <VehicleDetailModal vehicles={vehiculos} />

  <Footer />
</Layout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const brandFilter = document.getElementById('brand-filter') as HTMLSelectElement | null;
  const yearFilter = document.getElementById('year-filter') as HTMLSelectElement | null;
  const transmissionFilter = document.getElementById('transmission-filter') as HTMLSelectElement | null;
  const fuelFilter = document.getElementById('fuel-filter') as HTMLSelectElement | null;
  const priceFilter = document.getElementById('price-filter') as HTMLSelectElement | null;
  const clearFiltersButton = document.getElementById('clear-filters');
  const noResultsClearButton = document.getElementById('no-results-clear');
  const counter = document.getElementById('vehicle-counter');
  const noResults = document.getElementById('no-results');
  const vehiclesGrid = document.getElementById('vehicles-grid');
  const tabButtons = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const cards = document.querySelectorAll<HTMLElement>('.vehicle-card');
  const filtersToggle = document.getElementById('filters-toggle');
  const filtersPanel = document.getElementById('filters-panel');

  let activeTab = 'disponible';

  const normalize = (value: string) =>
    value
      .toLowerCase()
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .trim();

  function updateDisplay() {
    const term = normalize(searchInput?.value ?? '');
    const brand = normalize(brandFilter?.value ?? '');
    const year = yearFilter?.value ?? '';
    const transmission = normalize(transmissionFilter?.value ?? '');
    const fuel = normalize(fuelFilter?.value ?? '');
    const maxPrice = Number(priceFilter?.value ?? 0);
    let visible = 0;

    cards.forEach((card) => {
      const searchable = normalize(card.dataset.search ?? '');
      const estado = card.dataset.estado ?? '';
      const cardBrand = normalize(card.dataset.marca ?? '');
      const cardYear = card.dataset.anio ?? '';
      const cardTransmission = normalize(card.dataset.transmision ?? '');
      const cardFuel = normalize(card.dataset.combustible ?? '');
      const cardPrice = Number(card.dataset.precio ?? 0);

      const matches =
        (activeTab === 'todos' || estado === activeTab) &&
        (!term || searchable.includes(term)) &&
        (!brand || cardBrand === brand) &&
        (!year || cardYear === year) &&
        (!transmission || cardTransmission === transmission) &&
        (!fuel || cardFuel === fuel) &&
        (!maxPrice || cardPrice <= maxPrice);

      card.hidden = !matches;
      if (matches) visible++;
    });

    if (counter) {
      const estadoTexto =
        activeTab === 'todos'
          ? visible === 1 ? 'encontrado' : 'encontrados'
          : activeTab === 'vendido'
            ? visible === 1 ? 'vendido' : 'vendidos'
            : visible === 1 ? 'disponible' : 'disponibles';
      counter.textContent = `${visible} vehículo${visible === 1 ? '' : 's'} ${estadoTexto}`;
    }

    noResults?.classList.toggle('hidden', visible > 0);
    vehiclesGrid?.classList.toggle('hidden', visible === 0);
  }

  function setTab(tabId: string) {
    activeTab = tabId;

    tabButtons.forEach((button) => {
      const isActive = button.dataset.tab === tabId;
      button.dataset.active = String(isActive);
      button.setAttribute('aria-selected', String(isActive));
    });

    updateDisplay();
  }

  function clearFilters() {
    if (searchInput) searchInput.value = '';
    [brandFilter, yearFilter, transmissionFilter, fuelFilter, priceFilter].forEach((field) => {
      if (field) field.value = '';
    });
    setTab('disponible');
  }

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => setTab(button.dataset.tab ?? 'todos'));
  });

  [searchInput, brandFilter, yearFilter, transmissionFilter, fuelFilter, priceFilter].forEach((field) => {
    field?.addEventListener('input', updateDisplay);
    field?.addEventListener('change', updateDisplay);
  });

  clearFiltersButton?.addEventListener('click', clearFilters);
  noResultsClearButton?.addEventListener('click', clearFilters);

  const filtersToggleLabel = document.getElementById('filters-toggle-label');

  filtersToggle?.addEventListener('click', () => {
    if (!filtersPanel) return;
    const isHidden = filtersPanel.classList.toggle('hidden');
    filtersToggle.setAttribute('aria-expanded', String(!isHidden));
    if (filtersToggleLabel) {
      filtersToggleLabel.textContent = isHidden ? 'Mostrar filtros' : 'Ocultar filtros';
    }
  });

  // Presets desde la URL (ej. /catalogo?marca=Toyota&estado=todos)
  const params = new URLSearchParams(window.location.search);
  const presetMarca = params.get('marca');
  if (presetMarca && brandFilter) {
    const exists = Array.from(brandFilter.options).some((option) => option.value === presetMarca);
    if (exists) brandFilter.value = presetMarca;
  }
  const presetEstado = params.get('estado');
  const initialTab = presetEstado && ['todos', 'disponible', 'vendido'].includes(presetEstado)
    ? presetEstado
    : 'disponible';

  setTab(initialTab);
</script>
