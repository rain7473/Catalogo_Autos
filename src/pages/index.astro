---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VehicleCard from '../components/VehicleCard.astro';
import VehicleDetailModal from '../components/VehicleDetailModal.astro';
import { vehiculos } from '../vehiculos';

const disponibles = vehiculos.filter((vehiculo) => vehiculo.estado === 'disponible');
const precioMinimo = Math.min(...vehiculos.map((vehiculo) => vehiculo.precio));
const precioMaximo = Math.max(...vehiculos.map((vehiculo) => vehiculo.precio));
const marcas = [...new Set(vehiculos.map((vehiculo) => vehiculo.marca))].sort();
const transmisiones = [...new Set(vehiculos.map((vehiculo) => vehiculo.transmision))].sort();
const combustibles = [...new Set(vehiculos.map((vehiculo) => vehiculo.combustible))].sort();
const anios = [...new Set(vehiculos.map((vehiculo) => vehiculo.anio))].sort((a, b) => b - a);
---

<Layout>
  <Header />

  <section class="bg-gradient-to-br from-gray-950 via-gray-900 to-red-950 text-white">
    <div class="mx-auto max-w-7xl px-4 pb-16 pt-10 sm:px-6 sm:pb-20 sm:pt-14">
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-red-300">Catálogo de vehículos</p>
        <h1 class="max-w-2xl text-[2.5rem] font-extrabold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
          Encuentra tu <span class="text-red-300">próximo auto</span>
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-gray-300 sm:text-lg">
          Vehículos verificados en San Pedro Sula. Filtra por marca, precio y características, y consulta directo por WhatsApp.
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-gray-300">
          <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-2 font-semibold">
            <span class="h-2 w-2 rounded-full bg-green-400"></span>
            {disponibles.length} vehículos disponibles
          </span>
          <span class="rounded-full bg-white/10 px-3 py-2 font-semibold">
            Desde ${precioMinimo.toLocaleString('en-US')}
          </span>
        </div>
      </div>
    </div>
  </section>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <section class="-mt-16 mb-6 rounded-2xl border border-gray-200 bg-white p-4 shadow-xl sm:p-5" aria-label="Filtros del catálogo">
      <div class="grid gap-3 lg:grid-cols-[1fr_auto] lg:items-center">
        <label class="relative block">
          <span class="sr-only">Buscar vehículo</span>
          <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="search-input"
            type="search"
            placeholder="Buscar marca, modelo, transmisión o combustible"
            class="h-12 w-full rounded-xl border border-gray-200 bg-white pl-12 pr-4 text-base text-gray-900 placeholder-gray-400 shadow-sm outline-none transition focus:border-red-700 focus:ring-4 focus:ring-red-100"
          />
        </label>

        <div class="grid grid-cols-3 rounded-xl bg-gray-100 p-1 sm:flex" role="tablist" aria-label="Estado del vehículo">
          {[
            { id: 'todos', label: 'Todos' },
            { id: 'disponible', label: 'Disponibles' },
            { id: 'vendido', label: 'Vendidos' },
          ].map((tab) => (
            <button
              data-tab={tab.id}
              class="tab-btn h-10 min-w-0 cursor-pointer rounded-lg px-2 text-sm font-semibold text-gray-600 transition hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-red-700 focus:ring-offset-2 data-[active=true]:bg-red-700 data-[active=true]:text-white data-[active=true]:shadow-sm sm:px-4"
              type="button"
              role="tab"
              aria-selected={tab.id === 'disponible' ? 'true' : 'false'}
              data-active={tab.id === 'disponible' ? 'true' : 'false'}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        <label class="block">
          <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-gray-500">Marca</span>
          <select id="brand-filter" class="filter-field">
            <option value="">Todas</option>
            {marcas.map((marca) => <option value={marca}>{marca}</option>)}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-gray-500">Año</span>
          <select id="year-filter" class="filter-field">
            <option value="">Todos</option>
            {anios.map((anio) => <option value={anio}>{anio}</option>)}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-gray-500">Transmisión</span>
          <select id="transmission-filter" class="filter-field">
            <option value="">Todas</option>
            {transmisiones.map((transmision) => <option value={transmision}>{transmision}</option>)}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-gray-500">Combustible</span>
          <select id="fuel-filter" class="filter-field">
            <option value="">Todos</option>
            {combustibles.map((combustible) => <option value={combustible}>{combustible}</option>)}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-bold uppercase tracking-wide text-gray-500">Precio máximo</span>
          <select id="price-filter" class="filter-field">
            <option value="">Sin límite</option>
            <option value="22000">Hasta $22,000</option>
            <option value="25000">Hasta $25,000</option>
            <option value="30000">Hasta $30,000</option>
            <option value={precioMaximo}>Hasta ${precioMaximo.toLocaleString('en-US')}</option>
          </select>
        </label>
      </div>

      <div class="mt-4 flex flex-col gap-3 border-t border-gray-100 pt-4 sm:flex-row sm:items-center sm:justify-between">
        <p id="vehicle-counter" class="text-sm font-semibold text-gray-600">
          {disponibles.length} vehículos disponibles desde ${precioMinimo.toLocaleString('en-US')}
        </p>
        <button
          id="clear-filters"
          type="button"
          class="h-10 w-full cursor-pointer rounded-xl border border-gray-200 bg-white px-4 text-sm font-semibold text-gray-600 shadow-sm transition hover:border-red-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-red-700 focus:ring-offset-2 sm:w-auto"
        >
          Limpiar filtros
        </button>
      </div>
    </section>

    <section id="vehicles-grid" class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" aria-live="polite">
      {vehiculos.map((vehiculo) => (
        <VehicleCard vehiculo={vehiculo} />
      ))}
    </section>

    <section id="no-results" class="hidden py-16 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-gray-100">
        <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M8 16h8M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-gray-800">No hay vehículos con esos filtros</h2>
      <p class="mx-auto mt-2 max-w-sm text-sm leading-6 text-gray-500">
        Prueba quitando algún filtro o busca por otra marca/modelo.
      </p>
    </section>
  </main>

  <VehicleDetailModal vehicles={vehiculos} />

  <Footer />
</Layout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const brandFilter = document.getElementById('brand-filter') as HTMLSelectElement | null;
  const yearFilter = document.getElementById('year-filter') as HTMLSelectElement | null;
  const transmissionFilter = document.getElementById('transmission-filter') as HTMLSelectElement | null;
  const fuelFilter = document.getElementById('fuel-filter') as HTMLSelectElement | null;
  const priceFilter = document.getElementById('price-filter') as HTMLSelectElement | null;
  const clearFiltersButton = document.getElementById('clear-filters');
  const counter = document.getElementById('vehicle-counter');
  const noResults = document.getElementById('no-results');
  const tabButtons = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const cards = document.querySelectorAll<HTMLElement>('.vehicle-card');

  let activeTab = 'disponible';

  const normalize = (value: string) =>
    value
      .toLowerCase()
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .trim();

  function updateDisplay() {
    const term = normalize(searchInput?.value ?? '');
    const brand = normalize(brandFilter?.value ?? '');
    const year = yearFilter?.value ?? '';
    const transmission = normalize(transmissionFilter?.value ?? '');
    const fuel = normalize(fuelFilter?.value ?? '');
    const maxPrice = Number(priceFilter?.value ?? 0);
    let visible = 0;

    cards.forEach((card) => {
      const searchable = normalize(card.dataset.search ?? '');
      const estado = card.dataset.estado ?? '';
      const cardBrand = normalize(card.dataset.marca ?? '');
      const cardYear = card.dataset.anio ?? '';
      const cardTransmission = normalize(card.dataset.transmision ?? '');
      const cardFuel = normalize(card.dataset.combustible ?? '');
      const cardPrice = Number(card.dataset.precio ?? 0);

      const matches =
        (activeTab === 'todos' || estado === activeTab) &&
        (!term || searchable.includes(term)) &&
        (!brand || cardBrand === brand) &&
        (!year || cardYear === year) &&
        (!transmission || cardTransmission === transmission) &&
        (!fuel || cardFuel === fuel) &&
        (!maxPrice || cardPrice <= maxPrice);

      card.hidden = !matches;
      if (matches) visible++;
    });

    if (counter) {
      const estadoTexto =
        activeTab === 'todos'
          ? 'encontrados'
          : activeTab === 'vendido'
            ? visible === 1 ? 'vendido' : 'vendidos'
            : visible === 1 ? 'disponible' : 'disponibles';
      counter.textContent = `${visible} vehículo${visible === 1 ? '' : 's'} ${estadoTexto}`;
    }

    noResults?.classList.toggle('hidden', visible > 0);
  }

  function setTab(tabId: string) {
    activeTab = tabId;

    tabButtons.forEach((button) => {
      const isActive = button.dataset.tab === tabId;
      button.dataset.active = String(isActive);
      button.setAttribute('aria-selected', String(isActive));
    });

    updateDisplay();
  }

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => setTab(button.dataset.tab ?? 'todos'));
  });

  [searchInput, brandFilter, yearFilter, transmissionFilter, fuelFilter, priceFilter].forEach((field) => {
    field?.addEventListener('input', updateDisplay);
    field?.addEventListener('change', updateDisplay);
  });

  clearFiltersButton?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    [brandFilter, yearFilter, transmissionFilter, fuelFilter, priceFilter].forEach((field) => {
      if (field) field.value = '';
    });
    setTab('disponible');
  });

  setTab('disponible');
</script>
