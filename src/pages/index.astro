---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VehicleCard from '../components/VehicleCard.astro';
import VehicleDetailModal from '../components/VehicleDetailModal.astro';
import WhatsAppIcon from '../components/icons/WhatsAppIcon.astro';
import { vehiculos, WHATSAPP_BASE_URL } from '../vehiculos';

const disponibles = vehiculos.filter((vehiculo) => vehiculo.estado === 'disponible');
const destacados = disponibles.slice(0, 3);
const heroVehiculo = destacados[0];
const marcas = [...new Set(vehiculos.map((vehiculo) => vehiculo.marca))].sort();
const precioMinimo = Math.min(...(disponibles.length ? disponibles : vehiculos).map((vehiculo) => vehiculo.precio));

const waUrl = `${WHATSAPP_BASE_URL}?text=${encodeURIComponent('Hola, me interesa información sobre los vehículos disponibles en Autos La Fe.')}`;

const valores = [
  {
    titulo: 'Vehículos verificados',
    texto: 'Cada unidad pasa por revisión mecánica y documental antes de publicarse en el catálogo.',
    icono: 'check',
  },
  {
    titulo: 'Precios claros',
    texto: 'El precio que ves es el precio real. Sin cargos ocultos ni sorpresas al momento de cerrar.',
    icono: 'tag',
  },
  {
    titulo: 'Atención directa',
    texto: 'Hablas directo con nosotros por WhatsApp. Respuesta rápida, fotos adicionales y citas el mismo día.',
    icono: 'chat',
  },
  {
    titulo: 'Entrega sin complicaciones',
    texto: 'Te acompañamos en el traspaso y papeleo para que estrenes tu vehículo cuanto antes.',
    icono: 'key',
  },
];

const pasos = [
  {
    numero: '01',
    titulo: 'Explora el catálogo',
    texto: 'Filtra por marca, año, precio y características hasta encontrar el vehículo que buscas.',
  },
  {
    numero: '02',
    titulo: 'Consulta por WhatsApp',
    texto: 'Escríbenos directo desde la ficha del vehículo. Te respondemos con detalles, fotos y disponibilidad.',
  },
  {
    numero: '03',
    titulo: 'Agenda y estrena',
    texto: 'Ven a verlo en persona en San Pedro Sula, pruébalo y cierra el trato con confianza.',
  },
];
---

<Layout>
  <Header />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-zinc-950 text-white">
      <div class="bg-grid-dark absolute inset-0" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -top-48 right-[-12%] h-[520px] w-[520px] rounded-full bg-red-700/25 blur-[140px]" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -bottom-56 left-[-14%] h-[420px] w-[420px] rounded-full bg-red-900/20 blur-[130px]" aria-hidden="true"></div>

      <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-4 pb-16 pt-14 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16 lg:pb-24 lg:pt-20">
        <div>
          <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3.5 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-red-300">
            <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
            Concesionario en San Pedro Sula
          </p>

          <h1 class="mt-6 max-w-xl text-4xl font-black leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
            Tu próximo auto, <span class="text-red-500">verificado</span> y listo para estrenar
          </h1>

          <p class="mt-5 max-w-lg text-base leading-7 text-zinc-300 sm:text-lg sm:leading-8">
            Catálogo de vehículos seleccionados con revisión mecánica, precios claros y atención directa por WhatsApp.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a
              href="/catalogo"
              class="inline-flex h-12 cursor-pointer items-center justify-center gap-2 rounded-xl bg-red-700 px-6 text-sm font-bold text-white shadow-lg shadow-red-950/50 transition-colors duration-200 hover:bg-red-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
            >
              Explorar catálogo
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" />
                <path d="m13 6 6 6-6 6" />
              </svg>
            </a>
            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-12 cursor-pointer items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/5 px-6 text-sm font-bold text-white transition-colors duration-200 hover:border-white/40 hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
            >
              <WhatsAppIcon class="h-4 w-4 text-emerald-400" />
              Hablar por WhatsApp
            </a>
          </div>

          <dl class="mt-12 grid grid-cols-3 gap-4 border-t border-white/10 pt-8">
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-400">Disponibles</dt>
              <dd class="mt-1.5 text-2xl font-black tracking-tight text-white sm:text-3xl">{disponibles.length}</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-400">Marcas</dt>
              <dd class="mt-1.5 text-2xl font-black tracking-tight text-white sm:text-3xl">{marcas.length}</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-400">Desde</dt>
              <dd class="mt-1.5 text-2xl font-black tracking-tight text-red-500 sm:text-3xl">${precioMinimo.toLocaleString('en-US')}</dd>
            </div>
          </dl>
        </div>

        {heroVehiculo && (
          <div class="relative hidden lg:block">
            <div class="pointer-events-none absolute -inset-6 rounded-[2rem] bg-gradient-to-br from-red-700/30 via-transparent to-transparent blur-2xl" aria-hidden="true"></div>
            <article class="relative overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl backdrop-blur">
              <div class="relative aspect-[4/3] overflow-hidden">
                <img
                  src={heroVehiculo.imagen}
                  alt={`${heroVehiculo.nombre} ${heroVehiculo.anio}`}
                  class="h-full w-full object-cover"
                  loading="eager"
                  decoding="async"
                />
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-zinc-950/70 via-transparent to-transparent" aria-hidden="true"></div>
                <span class="absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-full bg-emerald-600 px-3 py-1 text-[11px] font-extrabold uppercase tracking-wide text-white">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-200"></span>
                  Disponible
                </span>
              </div>
              <div class="flex items-center justify-between gap-4 p-5">
                <div class="min-w-0">
                  <p class="text-[11px] font-extrabold uppercase tracking-[0.18em] text-red-400">Destacado de la semana</p>
                  <h2 class="mt-1 truncate text-lg font-extrabold tracking-tight text-white">
                    {heroVehiculo.nombre} {heroVehiculo.anio}
                  </h2>
                  <p class="mt-0.5 text-xl font-black text-white">${heroVehiculo.precio.toLocaleString('en-US')}</p>
                </div>
                <button
                  type="button"
                  data-vehicle-detail={heroVehiculo.id}
                  class="inline-flex h-11 flex-none cursor-pointer items-center justify-center rounded-xl bg-white px-4 text-sm font-bold text-zinc-950 transition-colors duration-200 hover:bg-zinc-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
                  aria-label={`Ver detalle de ${heroVehiculo.nombre} ${heroVehiculo.anio}`}
                >
                  Ver detalle
                </button>
              </div>
            </article>
          </div>
        )}
      </div>
    </section>

    <!-- Marcas -->
    <section class="border-b border-zinc-200 bg-white" aria-label="Marcas disponibles">
      <div class="mx-auto max-w-7xl px-4 py-9 sm:px-6">
        <p class="text-center text-xs font-extrabold uppercase tracking-[0.22em] text-zinc-400">
          Marcas en nuestro catálogo
        </p>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-2.5">
          {marcas.map((marca) => (
            <a
              href={`/catalogo?marca=${encodeURIComponent(marca)}`}
              class="inline-flex h-10 cursor-pointer items-center rounded-full border border-zinc-200 bg-zinc-50 px-5 text-sm font-bold text-zinc-700 transition-colors duration-200 hover:border-red-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
            >
              {marca}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Destacados -->
    <section class="bg-zinc-50" aria-labelledby="destacados-titulo">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:py-20">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-red-700">Recién llegados</p>
            <h2 id="destacados-titulo" class="mt-2 text-3xl font-black tracking-tight text-zinc-950 sm:text-4xl">
              Vehículos destacados
            </h2>
            <p class="mt-3 max-w-xl text-base leading-7 text-zinc-600">
              Una selección de las mejores unidades disponibles ahora mismo. Todas verificadas y listas para entrega.
            </p>
          </div>
          <a
            href="/catalogo"
            class="inline-flex h-11 cursor-pointer items-center gap-2 rounded-xl border border-zinc-300 bg-white px-5 text-sm font-bold text-zinc-800 shadow-sm transition-colors duration-200 hover:border-red-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
          >
            Ver catálogo completo
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" />
              <path d="m13 6 6 6-6 6" />
            </svg>
          </a>
        </div>

        <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {destacados.map((vehiculo) => (
            <VehicleCard vehiculo={vehiculo} />
          ))}
        </div>
      </div>
    </section>

    <!-- Por qué elegirnos -->
    <section class="bg-white" aria-labelledby="valores-titulo">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-red-700">Por qué Autos La Fe</p>
          <h2 id="valores-titulo" class="mt-2 text-3xl font-black tracking-tight text-zinc-950 sm:text-4xl">
            Comprar un auto usado, sin el riesgo de siempre
          </h2>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {valores.map((valor) => (
            <div class="group rounded-2xl border border-zinc-200 bg-zinc-50 p-6 transition-colors duration-200 hover:border-red-200 hover:bg-red-50/40">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-red-700 text-white shadow-md shadow-red-200">
                {valor.icono === 'check' && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z" />
                    <path d="m9 12 2 2 4-4" />
                  </svg>
                )}
                {valor.icono === 'tag' && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z" />
                    <circle cx="7.5" cy="7.5" r="1" fill="currentColor" />
                  </svg>
                )}
                {valor.icono === 'chat' && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z" />
                  </svg>
                )}
                {valor.icono === 'key' && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z" />
                    <circle cx="16.5" cy="7.5" r="1" fill="currentColor" />
                  </svg>
                )}
              </span>
              <h3 class="mt-5 text-base font-extrabold tracking-tight text-zinc-950">{valor.titulo}</h3>
              <p class="mt-2 text-sm leading-6 text-zinc-600">{valor.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section class="border-t border-zinc-200 bg-zinc-50" aria-labelledby="pasos-titulo">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-red-700">Proceso simple</p>
          <h2 id="pasos-titulo" class="mt-2 text-3xl font-black tracking-tight text-zinc-950 sm:text-4xl">
            Así de fácil estrenas con nosotros
          </h2>
        </div>

        <ol class="mt-12 grid gap-5 lg:grid-cols-3">
          {pasos.map((paso) => (
            <li class="relative rounded-2xl border border-zinc-200 bg-white p-7 shadow-sm">
              <span class="text-4xl font-black tracking-tight text-red-700/15">{paso.numero}</span>
              <h3 class="mt-3 text-lg font-extrabold tracking-tight text-zinc-950">{paso.titulo}</h3>
              <p class="mt-2 text-sm leading-6 text-zinc-600">{paso.texto}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- CTA final -->
    <section class="relative overflow-hidden bg-zinc-950 text-white" aria-labelledby="cta-titulo">
      <div class="bg-grid-dark absolute inset-0" aria-hidden="true"></div>
      <div class="pointer-events-none absolute left-1/2 top-1/2 h-[420px] w-[680px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-red-700/25 blur-[130px]" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 lg:py-24">
        <h2 id="cta-titulo" class="text-3xl font-black tracking-tight sm:text-4xl lg:text-5xl">
          ¿Listo para encontrar tu próximo auto?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-7 text-zinc-300 sm:text-lg">
          Explora el catálogo o escríbenos directo. Te ayudamos a elegir el vehículo que mejor se ajusta a tu presupuesto.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/catalogo"
            class="inline-flex h-12 cursor-pointer items-center justify-center gap-2 rounded-xl bg-red-700 px-6 text-sm font-bold text-white shadow-lg shadow-red-950/50 transition-colors duration-200 hover:bg-red-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
          >
            Ver catálogo
          </a>
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-12 cursor-pointer items-center justify-center gap-2 rounded-xl bg-emerald-600 px-6 text-sm font-bold text-white transition-colors duration-200 hover:bg-emerald-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
          >
            <WhatsAppIcon class="h-4 w-4" />
            Escribir por WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <VehicleDetailModal vehicles={vehiculos} />

  <Footer />
</Layout>
