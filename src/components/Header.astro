---
import { WHATSAPP_BASE_URL } from '../vehiculos';
import BrandLogo from './BrandLogo.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

const waUrl = `${WHATSAPP_BASE_URL}?text=${encodeURIComponent('Hola, me interesa información sobre los vehículos disponibles en Autos La Fe.')}`;

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Inicio', active: currentPath === '/' },
  { href: '/catalogo', label: 'Catálogo', active: currentPath.startsWith('/catalogo') },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-zinc-950/90 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-screen-2xl items-center justify-between gap-2 px-3 sm:h-[4.5rem] sm:gap-3 sm:px-6 lg:px-8">
    <a
      href="/"
      class="inline-flex shrink-0 items-center py-1.5 sm:py-2 rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
      aria-label="Autos La Fe, ir al inicio"
    >
      <BrandLogo variant="dark" size="lg" />
    </a>

    <nav class="flex items-center gap-1" aria-label="Navegación principal">
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={link.active ? 'page' : undefined}
          class={`inline-flex h-10 cursor-pointer items-center rounded-lg px-2.5 text-sm font-bold transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 sm:px-4 ${
            link.active
              ? 'bg-white/10 text-white'
              : 'text-zinc-400 hover:bg-white/5 hover:text-white'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex flex-none items-center gap-2">
      <a
        href="/admin"
        class="hidden h-10 cursor-pointer items-center justify-center rounded-lg px-3 text-sm font-bold text-zinc-400 transition-colors duration-200 hover:bg-white/5 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 md:inline-flex"
      >
        Admin
      </a>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-10 cursor-pointer items-center justify-center gap-2 rounded-lg bg-emerald-600 px-3 text-sm font-bold text-white shadow-sm transition-colors duration-200 hover:bg-emerald-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 sm:px-4"
        aria-label="Consultar por WhatsApp"
      >
        <WhatsAppIcon class="h-4 w-4 flex-none" />
        <span class="hidden sm:inline">WhatsApp</span>
      </a>
    </div>
  </div>
</header>
