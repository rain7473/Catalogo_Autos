---
import { WHATSAPP_BASE_URL, WHATSAPP_NUMBER } from '../vehiculos';
import BrandLogo from './BrandLogo.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

const waUrl = `${WHATSAPP_BASE_URL}?text=${encodeURIComponent('Hola, me interesa información sobre los vehículos de Autos La Fe.')}`;
const phoneDisplay = `+${WHATSAPP_NUMBER.slice(0, 3)} ${WHATSAPP_NUMBER.slice(3, 7)}-${WHATSAPP_NUMBER.slice(7)}`;
---

<footer class="mt-auto bg-zinc-950 text-zinc-400">
  <div class="h-px bg-gradient-to-r from-transparent via-red-700/80 to-transparent"></div>

  <div class="mx-auto grid max-w-screen-2xl gap-10 px-4 py-14 sm:grid-cols-2 sm:px-6 lg:grid-cols-[1.4fr_0.8fr_1fr_1.2fr] lg:gap-8 lg:px-8">
    <div>
      <a href="/" class="inline-block rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950">
        <BrandLogo variant="dark" />
      </a>
      <p class="mt-4 max-w-xs text-sm leading-6">
        Vehículos verificados y listos para estrenar en San Pedro Sula. Atención directa, precios claros y trato de confianza.
      </p>
    </div>

    <nav aria-label="Navegación del pie de página">
      <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-zinc-500">Explorar</p>
      <ul class="mt-4 space-y-2.5 text-sm font-semibold">
        <li><a href="/" class="cursor-pointer transition-colors duration-200 hover:text-white">Inicio</a></li>
        <li><a href="/catalogo" class="cursor-pointer transition-colors duration-200 hover:text-white">Catálogo</a></li>
        <li><a href="/catalogo?estado=disponible" class="cursor-pointer transition-colors duration-200 hover:text-white">Disponibles</a></li>
        <li><a href="/admin" class="cursor-pointer transition-colors duration-200 hover:text-white">Admin</a></li>
      </ul>
    </nav>

    <div>
      <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-zinc-500">Contacto</p>
      <ul class="mt-4 space-y-3 text-sm">
        <li class="flex items-start gap-2.5">
          <svg class="mt-0.5 h-4 w-4 flex-none text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>San Pedro Sula, Honduras</span>
        </li>
        <li class="flex items-start gap-2.5">
          <svg class="mt-0.5 h-4 w-4 flex-none text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 6v6l4 2" />
          </svg>
          <span>Lun – Sáb · 8:00 a.m. – 5:00 p.m.</span>
        </li>
        <li class="flex items-start gap-2.5">
          <WhatsAppIcon class="mt-0.5 h-4 w-4 flex-none text-red-500" />
          <a href={waUrl} target="_blank" rel="noopener noreferrer" class="cursor-pointer font-semibold transition-colors duration-200 hover:text-white">
            {phoneDisplay}
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <p class="text-base font-extrabold text-white">¿Listo para estrenar?</p>
      <p class="mt-2 text-sm leading-6">
        Escríbenos y te ayudamos a encontrar el vehículo ideal para ti.
      </p>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex h-11 w-full cursor-pointer items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 text-sm font-bold text-white transition-colors duration-200 hover:bg-emerald-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
      >
        <WhatsAppIcon class="h-4 w-4" />
        Consultar por WhatsApp
      </a>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-screen-2xl flex-col items-center justify-between gap-2 px-4 py-5 text-xs text-zinc-500 sm:flex-row sm:px-6 lg:px-8">
      <p>© {new Date().getFullYear()} Autos La Fe. Todos los derechos reservados.</p>
      <p>San Pedro Sula · Honduras</p>
    </div>
  </div>
</footer>
