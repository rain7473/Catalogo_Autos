---
import type { Vehiculo } from '../vehiculos';
import { WHATSAPP_BASE_URL } from '../vehiculos';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

interface Props {
  vehiculo: Vehiculo;
}

const { vehiculo } = Astro.props;

const precioFormateado = vehiculo.precio.toLocaleString('en-US');
const kmFormateado = vehiculo.km.toLocaleString('en-US');
const esDisponible = vehiculo.estado === 'disponible';
const searchable = [
  vehiculo.nombre,
  vehiculo.marca,
  vehiculo.anio,
  vehiculo.transmision,
  vehiculo.combustible,
].join(' ');

const waMessage = encodeURIComponent(
  `Hola, me interesa el ${vehiculo.nombre} ${vehiculo.anio}. ¿Está disponible?`
);
const waUrl = `${WHATSAPP_BASE_URL}?text=${waMessage}`;
---

<article
  class="vehicle-card group flex min-w-0 flex-col overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-red-200 hover:shadow-xl hover:shadow-zinc-950/10"
  data-estado={vehiculo.estado}
  data-nombre={vehiculo.nombre.toLowerCase()}
  data-marca={vehiculo.marca}
  data-transmision={vehiculo.transmision}
  data-combustible={vehiculo.combustible}
  data-search={searchable}
  data-anio={vehiculo.anio}
  data-precio={vehiculo.precio}
>
  <div class="relative aspect-[4/3] overflow-hidden bg-zinc-900">
    <img
      src={vehiculo.imagen}
      alt={`${vehiculo.nombre} ${vehiculo.anio}`}
      class={`h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04] ${esDisponible ? '' : 'grayscale'}`}
      loading="lazy"
      decoding="async"
    />

    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-zinc-950/80 via-zinc-950/10 to-transparent"></div>

    <div class="absolute left-3 top-3 flex items-center gap-2">
      <span
        class={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-extrabold uppercase tracking-wide text-white shadow-sm ${
          esDisponible ? 'bg-emerald-600' : 'bg-zinc-700'
        }`}
      >
        <span class={`h-1.5 w-1.5 rounded-full ${esDisponible ? 'bg-emerald-200' : 'bg-zinc-400'}`}></span>
        {esDisponible ? 'Disponible' : 'Vendido'}
      </span>
    </div>

    <span class="absolute right-3 top-3 rounded-full bg-zinc-950/70 px-2.5 py-1 text-[11px] font-extrabold text-white backdrop-blur">
      {vehiculo.anio}
    </span>

    <div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-3 p-4">
      <div class="min-w-0">
        <p class="truncate text-[11px] font-extrabold uppercase tracking-[0.18em] text-zinc-300">
          {vehiculo.marca}
        </p>
        <p class="mt-0.5 text-2xl font-black tracking-tight text-white drop-shadow-sm">
          ${precioFormateado}
        </p>
      </div>
    </div>
  </div>

  <div class="flex flex-1 flex-col p-4 sm:p-5">
    <h2 class="min-h-[2.75rem] text-lg font-extrabold leading-snug tracking-tight text-zinc-950">
      {vehiculo.nombre} <span class="font-bold text-zinc-400">{vehiculo.anio}</span>
    </h2>

    <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold text-zinc-600">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-zinc-50 px-2.5 py-1 ring-1 ring-zinc-200">
        <svg class="h-3.5 w-3.5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 12m-8 0a8 8 0 1 0 16 0 8 8 0 1 0-16 0" />
          <path d="m14.5 9.5-3 3" />
          <path d="M12 6v1" />
          <path d="M6 12h1" />
          <path d="M17 12h1" />
        </svg>
        {kmFormateado} km
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-zinc-50 px-2.5 py-1 ring-1 ring-zinc-200">
        <svg class="h-3.5 w-3.5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="17" cy="17" r="3" />
          <circle cx="7" cy="7" r="3" />
          <path d="M7 10v4a3 3 0 0 0 3 3h4" />
        </svg>
        {vehiculo.transmision}
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-zinc-50 px-2.5 py-1 ring-1 ring-zinc-200">
        <svg class="h-3.5 w-3.5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 22V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v17" />
          <path d="M2 22h12" />
          <path d="M13 9h4l3 3v6a2 2 0 1 1-4 0v-4h-3" />
          <path d="M6 7h4" />
        </svg>
        {vehiculo.combustible}
      </span>
    </div>

    <div class="mt-auto flex items-center gap-2 pt-5">
      <button
        type="button"
        data-vehicle-detail={vehiculo.id}
        class="inline-flex h-11 min-w-0 flex-1 cursor-pointer items-center justify-center rounded-xl bg-red-700 px-3 text-sm font-bold text-white shadow-sm transition-colors duration-200 hover:bg-red-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
        aria-label={`Ver detalle de ${vehiculo.nombre} ${vehiculo.anio}`}
      >
        Ver detalle
      </button>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-11 w-11 flex-none cursor-pointer items-center justify-center rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-700 transition-colors duration-200 hover:bg-emerald-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 focus-visible:ring-offset-2"
        aria-label={`Consultar por WhatsApp sobre ${vehiculo.nombre} ${vehiculo.anio}`}
      >
        <WhatsAppIcon class="h-5 w-5" />
      </a>
    </div>
  </div>
</article>
