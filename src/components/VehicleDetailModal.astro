---
import type { Vehiculo } from '../vehiculos';
import { WHATSAPP_BASE_URL } from '../vehiculos';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

interface Props {
  vehicles: Vehiculo[];
}

const { vehicles } = Astro.props;
const modalPayload = JSON.stringify({
  vehicles,
  whatsappBaseUrl: WHATSAPP_BASE_URL,
}).replace(/</g, '\\u003c');
---

<div
  id="vehicle-detail-modal"
  class="vehicle-detail-modal fixed inset-0 z-[80] flex items-center justify-center p-3 sm:p-4"
  aria-hidden="true"
  hidden
>
  <button
    type="button"
    class="vehicle-detail-overlay absolute inset-0 bg-zinc-950/80 backdrop-blur-sm"
    data-modal-close
    aria-label="Cerrar detalle"
  ></button>

  <section
    class="vehicle-detail-panel relative z-10 grid max-h-[92vh] w-full max-w-6xl overflow-hidden rounded-2xl bg-white text-zinc-950 shadow-2xl lg:grid-cols-[1.05fr_0.95fr]"
    role="dialog"
    aria-modal="true"
    aria-labelledby="vehicle-modal-title"
  >
    <button
      type="button"
      class="absolute right-4 top-4 z-20 flex h-10 w-10 cursor-pointer items-center justify-center rounded-full bg-white/95 text-zinc-700 shadow-lg ring-1 ring-zinc-200 transition-colors duration-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700"
      data-modal-close
      aria-label="Cerrar"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="overflow-y-auto bg-zinc-950 p-4 sm:p-5 lg:max-h-[92vh]">
      <div class="relative overflow-hidden rounded-xl bg-zinc-900 ring-1 ring-white/10">
        <img
          id="vehicle-modal-image"
          src=""
          alt=""
          class="aspect-[4/3] w-full object-cover"
        />

        <button
          type="button"
          id="vehicle-modal-prev"
          class="absolute left-3 top-1/2 hidden h-11 w-11 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full bg-white/90 text-zinc-900 shadow-lg transition-colors duration-200 hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700"
          aria-label="Imagen anterior"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="m15 18-6-6 6-6" />
          </svg>
        </button>

        <button
          type="button"
          id="vehicle-modal-next"
          class="absolute right-3 top-1/2 hidden h-11 w-11 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full bg-white/90 text-zinc-900 shadow-lg transition-colors duration-200 hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700"
          aria-label="Siguiente imagen"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="m9 18 6-6-6-6" />
          </svg>
        </button>
      </div>

      <div id="vehicle-modal-thumbs" class="mt-3 grid grid-cols-3 gap-2 sm:grid-cols-4"></div>
    </div>

    <div class="max-h-[92vh] overflow-y-auto p-5 sm:p-7">
      <div class="pr-10">
        <p id="vehicle-modal-brand" class="text-xs font-extrabold uppercase tracking-[0.2em] text-red-700"></p>
        <h2 id="vehicle-modal-title" class="mt-2 text-2xl font-black tracking-tight text-zinc-950 sm:text-3xl"></h2>
        <p id="vehicle-modal-description" class="mt-3 text-sm leading-6 text-zinc-600 sm:text-base sm:leading-7"></p>
      </div>

      <div class="mt-5 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-zinc-200 bg-zinc-50 p-4 sm:p-5">
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-500">Precio</p>
          <p id="vehicle-modal-price" class="mt-1 text-3xl font-black tracking-tight text-red-700"></p>
        </div>
        <span id="vehicle-modal-status" class="inline-flex rounded-full px-3 py-1.5 text-sm font-extrabold"></span>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3">
        <div class="rounded-xl border border-zinc-200 bg-white p-4">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-500">Modelo</p>
          <p id="vehicle-modal-model" class="mt-1 text-base font-extrabold text-zinc-950"></p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-4">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-500">Año</p>
          <p id="vehicle-modal-year" class="mt-1 text-base font-extrabold text-zinc-950"></p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-4">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-500">Kilometraje</p>
          <p id="vehicle-modal-km" class="mt-1 text-base font-extrabold text-zinc-950"></p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-4">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-500">Transmisión</p>
          <p id="vehicle-modal-transmission" class="mt-1 text-base font-extrabold text-zinc-950"></p>
        </div>
        <div class="col-span-2 rounded-xl border border-zinc-200 bg-white p-4">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-500">Combustible</p>
          <p id="vehicle-modal-fuel" class="mt-1 text-base font-extrabold text-zinc-950"></p>
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <a
          id="vehicle-modal-whatsapp"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-12 cursor-pointer items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 text-sm font-extrabold text-white shadow-sm transition-colors duration-200 hover:bg-emerald-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 focus-visible:ring-offset-2"
        >
          <WhatsAppIcon class="h-4 w-4" />
          Consultar por WhatsApp
        </a>
        <button
          type="button"
          class="inline-flex h-12 cursor-pointer items-center justify-center rounded-xl border border-zinc-200 bg-white px-4 text-sm font-extrabold text-zinc-700 transition-colors duration-200 hover:border-red-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
          data-modal-close
        >
          Volver al catálogo
        </button>
      </div>
    </div>
  </section>
</div>

<script id="vehicles-detail-data" type="application/json" set:html={modalPayload}></script>

<script>
  import type { Vehiculo } from '../vehiculos';

  interface DetailData {
    vehicles: Vehiculo[];
    whatsappBaseUrl: string;
  }

  const detailDataNode = document.getElementById('vehicles-detail-data');
  const detailData = JSON.parse(detailDataNode?.textContent || '{"vehicles":[]}') as DetailData;
  const detailVehicles = detailData.vehicles ?? [];
  const whatsappBaseUrl = detailData.whatsappBaseUrl ?? '';

  const modal = document.getElementById('vehicle-detail-modal');
  const modalImage = document.getElementById('vehicle-modal-image');
  const modalPrev = document.getElementById('vehicle-modal-prev');
  const modalNext = document.getElementById('vehicle-modal-next');
  const modalThumbs = document.getElementById('vehicle-modal-thumbs');
  const modalWhatsapp = document.getElementById('vehicle-modal-whatsapp');

  const detailFields = {
    brand: document.getElementById('vehicle-modal-brand'),
    title: document.getElementById('vehicle-modal-title'),
    description: document.getElementById('vehicle-modal-description'),
    model: document.getElementById('vehicle-modal-model'),
    year: document.getElementById('vehicle-modal-year'),
    price: document.getElementById('vehicle-modal-price'),
    km: document.getElementById('vehicle-modal-km'),
    transmission: document.getElementById('vehicle-modal-transmission'),
    fuel: document.getElementById('vehicle-modal-fuel'),
    status: document.getElementById('vehicle-modal-status'),
  };

  const currency = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0,
  });
  const number = new Intl.NumberFormat('en-US');

  let selectedVehicle: Vehiculo | null = null;
  let currentImageIndex = 0;
  let closeTimer = 0;

  function getVehicleImages(vehicle: Vehiculo): string[] {
    const images =
      Array.isArray(vehicle.images) && vehicle.images.length > 0
        ? vehicle.images
        : [vehicle.imagen].filter((src): src is string => Boolean(src));
    return images.length > 0 ? images : ['https://placehold.co/960x640/18181b/fafafa?text=Vehiculo'];
  }

  function renderCarousel() {
    if (!selectedVehicle || !modalImage || !modalThumbs || !modalPrev || !modalNext) return;

    const images = getVehicleImages(selectedVehicle);
    currentImageIndex = Math.max(0, Math.min(currentImageIndex, images.length - 1));
    const activeImage = images[currentImageIndex];

    modalImage.setAttribute('src', activeImage);
    modalImage.setAttribute('alt', `${selectedVehicle.nombre} ${selectedVehicle.anio}`);

    const showNavigation = images.length > 1;
    modalPrev.classList.toggle('hidden', !showNavigation);
    modalPrev.classList.toggle('flex', showNavigation);
    modalNext.classList.toggle('hidden', !showNavigation);
    modalNext.classList.toggle('flex', showNavigation);

    modalThumbs.innerHTML = '';
    const vehicle = selectedVehicle;
    images.forEach((image, index) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = [
        'cursor-pointer overflow-hidden rounded-lg ring-2 transition focus:outline-none focus-visible:ring-red-600',
        index === currentImageIndex ? 'ring-red-600' : 'ring-transparent opacity-70 hover:opacity-100 hover:ring-red-900',
      ].join(' ');
      button.setAttribute('aria-label', `Ver imagen ${index + 1}`);
      button.addEventListener('click', () => {
        currentImageIndex = index;
        renderCarousel();
      });

      const img = document.createElement('img');
      img.src = image;
      img.alt = `${vehicle.nombre} miniatura ${index + 1}`;
      img.className = 'aspect-[4/3] w-full object-cover';
      img.loading = 'lazy';

      button.appendChild(img);
      modalThumbs.appendChild(button);
    });
  }

  function setText(node: Element | null, value: unknown) {
    if (node) node.textContent = String(value ?? '');
  }

  function openVehicleDetail(vehicle: Vehiculo | undefined) {
    if (!vehicle || !modal || !modalWhatsapp) return;

    window.clearTimeout(closeTimer);
    selectedVehicle = vehicle;
    currentImageIndex = 0;

    const price = currency.format(Number(vehicle.precio || 0));
    const model = vehicle.modelo || vehicle.nombre.replace(vehicle.marca, '').trim() || vehicle.nombre;
    const statusLabel = vehicle.estado === 'disponible' ? 'Disponible' : 'Vendido';

    setText(detailFields.brand, vehicle.marca);
    setText(detailFields.title, `${vehicle.nombre} ${vehicle.anio}`);
    setText(detailFields.description, vehicle.descripcion || 'Vehículo verificado, listo para inspección y consulta directa.');
    setText(detailFields.model, model);
    setText(detailFields.year, vehicle.anio);
    setText(detailFields.price, price);
    setText(detailFields.km, `${number.format(Number(vehicle.km || 0))} km`);
    setText(detailFields.transmission, vehicle.transmision);
    setText(detailFields.fuel, vehicle.combustible);
    setText(detailFields.status, statusLabel);

    detailFields.status?.classList.toggle('bg-emerald-100', vehicle.estado === 'disponible');
    detailFields.status?.classList.toggle('text-emerald-700', vehicle.estado === 'disponible');
    detailFields.status?.classList.toggle('bg-zinc-200', vehicle.estado !== 'disponible');
    detailFields.status?.classList.toggle('text-zinc-700', vehicle.estado !== 'disponible');

    const message = encodeURIComponent(
      `Hola, estoy interesado en el ${vehicle.nombre} ${vehicle.anio} de ${price}. ¿Sigue disponible?`
    );
    modalWhatsapp.setAttribute('href', `${whatsappBaseUrl}?text=${message}`);

    renderCarousel();

    modal.hidden = false;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => modal.classList.add('is-open'));
  }

  function closeVehicleDetail() {
    if (!modal || modal.hidden) return;

    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    closeTimer = window.setTimeout(() => {
      modal.hidden = true;
      selectedVehicle = null;
      currentImageIndex = 0;
    }, 190);
  }

  (window as any).openVehicleDetail = openVehicleDetail;
  (window as any).closeVehicleDetail = closeVehicleDetail;

  document.querySelectorAll('[data-vehicle-detail]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const vehicleId = Number(trigger.getAttribute('data-vehicle-detail'));
      const vehicle = detailVehicles.find((item) => Number(item.id) === vehicleId);
      openVehicleDetail(vehicle);
    });
  });

  document.querySelectorAll('[data-modal-close]').forEach((button) => {
    button.addEventListener('click', closeVehicleDetail);
  });

  modalPrev?.addEventListener('click', () => {
    if (!selectedVehicle) return;
    const images = getVehicleImages(selectedVehicle);
    currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
    renderCarousel();
  });

  modalNext?.addEventListener('click', () => {
    if (!selectedVehicle) return;
    const images = getVehicleImages(selectedVehicle);
    currentImageIndex = (currentImageIndex + 1) % images.length;
    renderCarousel();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeVehicleDetail();
  });
</script>
